# Backend Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit the real .env file to version control.

# -----------------------------------------------------------------
# DATABASE (Supabase / PostgreSQL)
# -----------------------------------------------------------------

# Transaction Pooler URL (used by Prisma for all runtime queries).
# For Supabase: use the "Transaction" or "Session" mode pooler URL.
# For local PostgreSQL: set both DATABASE_URL and DIRECT_URL to the same string.
DATABASE_URL="postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct (non-pooled) URL (used by Prisma Migrate and introspection only).
# For Supabase: use the direct connection string from your project settings.
DIRECT_URL="postgresql://postgres.your-project-ref:your-db-password@db.your-project-ref.supabase.co:5432/postgres"

# -----------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------

# Secret key used to sign and verify JWT tokens.
# Must be a long, random, unpredictable string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-this-with-a-long-random-secret-string-at-least-64-characters"

# -----------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------

# Port the Express server listens on.
PORT=5000
